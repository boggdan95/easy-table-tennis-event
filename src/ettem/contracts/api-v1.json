{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/boggdan95/ettem-cloud/contracts/api-v1.json",
  "title": "ETTEM Cloud ↔ Desktop API v1",
  "description": "JSON Schema contract for the two RPCs that bridge the cloud portal and the desktop app: pull_tournament (cloud → desktop) and push_results (desktop → cloud). Cloud is authoritative for UUIDs; desktop holds local integer IDs and maps them via cloud_*_id columns. V1 covers singles only — pair/team shapes are defined for forward compatibility but RPCs reject event_type != 'singles'.",
  "version": "1.0.0",

  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "iso3166_alpha3": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 3166-1 alpha-3 country code (ESP, MEX, GTM, ...)"
    },
    "iso_date": {
      "type": "string",
      "format": "date",
      "description": "YYYY-MM-DD"
    },
    "iso_datetime": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 / ISO 8601 timestamp in UTC"
    },
    "gender": {
      "type": "string",
      "enum": ["M", "F", "X"]
    },
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Major.minor version of this contract. Bump minor for additive changes, major for breaking."
    },
    "device_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Stable per-device identifier generated by the desktop app on first launch. Stored in .ettem/device_id. Opaque to cloud; used for lock acquisition and audit."
    },

    "event_type": {
      "type": "string",
      "enum": ["singles", "doubles", "teams"],
      "description": "V1 RPCs only accept 'singles'. Other values are reserved for V2."
    },
    "team_system": {
      "type": "string",
      "enum": ["swaythling", "corbillon", "olympic"],
      "description": "Required iff event_type='teams'. V1: rejected by RPCs."
    },
    "match_format": {
      "type": "string",
      "enum": ["bo3", "bo5", "bo7"]
    },
    "tournament_status": {
      "type": "string",
      "enum": ["draft", "registration_open", "registration_closed", "locked_for_run", "closed"]
    },
    "event_status": {
      "type": "string",
      "enum": ["draft", "open", "closed"]
    },
    "registration_status": {
      "type": "string",
      "enum": ["pending", "confirmed", "cancelled"]
    },

    "tenant_branding": {
      "type": "object",
      "description": "Tenant metadata included in pull responses so desktop can render branded reports/printouts offline.",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "slug": { "type": "string", "minLength": 2, "maxLength": 50 },
        "name": { "type": "string" },
        "country_cd": { "$ref": "#/$defs/iso3166_alpha3" },
        "organizer_name": { "type": ["string", "null"] },
        "logo_url": { "type": ["string", "null"], "format": "uri" },
        "primary_color": { "type": ["string", "null"], "pattern": "^#[0-9A-Fa-f]{6}$" }
      },
      "required": ["id", "slug", "name", "country_cd"],
      "additionalProperties": false
    },

    "category": {
      "type": "object",
      "description": "ITTF category or tenant extension. The 'code' field is what desktop already uses everywhere (PlayerORM.categoria, MatchORM.category) — pull payload maps cloud category UUIDs to these codes.",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9]{2,16}$",
          "description": "Stable string like U15BS, MS, WS. Same identifier the desktop has used since V1."
        },
        "name": { "type": "string" },
        "age_band": { "type": ["integer", "null"], "minimum": 0 },
        "gender": { "$ref": "#/$defs/gender" },
        "is_global": {
          "type": "boolean",
          "description": "true = global ITTF seed row (tenant_id IS NULL in cloud), false = tenant extension"
        }
      },
      "required": ["id", "code", "name", "gender", "is_global"],
      "additionalProperties": false
    },

    "player": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "external_id": { "type": ["string", "null"] },
        "first_name": { "type": "string", "minLength": 1 },
        "last_name": { "type": "string", "minLength": 1 },
        "gender": { "type": "string", "enum": ["M", "F"] },
        "country_cd": { "type": ["string", "null"], "pattern": "^[A-Z]{3}$" },
        "birth_date": { "type": ["string", "null"], "format": "date" },
        "default_category_id": { "type": ["string", "null"], "format": "uuid" },
        "ranking_pts": { "type": "integer", "minimum": 0 }
      },
      "required": ["id", "first_name", "last_name", "gender", "ranking_pts"],
      "additionalProperties": false
    },

    "pair": {
      "type": "object",
      "description": "Doubles pair. V2.",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "type": ["string", "null"] },
        "player1_id": { "$ref": "#/$defs/uuid" },
        "player2_id": { "$ref": "#/$defs/uuid" }
      },
      "required": ["id", "player1_id", "player2_id"],
      "additionalProperties": false
    },

    "team": {
      "type": "object",
      "description": "Team entity. V2.",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "type": "string" },
        "country_cd": { "type": ["string", "null"], "pattern": "^[A-Z]{3}$" },
        "member_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/uuid" },
          "minItems": 2,
          "maxItems": 6
        }
      },
      "required": ["id", "name", "member_ids"],
      "additionalProperties": false
    },

    "registration": {
      "type": "object",
      "description": "Exactly one of player_id, pair_id, team_id is non-null — matches the cloud schema constraint.",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "event_id": { "$ref": "#/$defs/uuid" },
        "player_id": { "type": ["string", "null"], "format": "uuid" },
        "pair_id": { "type": ["string", "null"], "format": "uuid" },
        "team_id": { "type": ["string", "null"], "format": "uuid" },
        "seed": { "type": ["integer", "null"], "minimum": 1 },
        "status": { "$ref": "#/$defs/registration_status" }
      },
      "required": ["id", "event_id", "status"],
      "additionalProperties": false,
      "allOf": [
        {
          "description": "Exactly one of player_id / pair_id / team_id must be non-null. Expressed as oneOf for clarity.",
          "oneOf": [
            { "required": ["player_id"], "properties": { "player_id": { "type": "string" } } },
            { "required": ["pair_id"],   "properties": { "pair_id":   { "type": "string" } } },
            { "required": ["team_id"],   "properties": { "team_id":   { "type": "string" } } }
          ]
        }
      ]
    },

    "event_spec": {
      "type": "object",
      "description": "One sub-tournament inside a tournament, scoped to a category.",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "category_id": { "$ref": "#/$defs/uuid" },
        "event_type": { "$ref": "#/$defs/event_type" },
        "team_system": {
          "anyOf": [
            { "$ref": "#/$defs/team_system" },
            { "type": "null" }
          ]
        },
        "format": { "$ref": "#/$defs/match_format" },
        "status": { "$ref": "#/$defs/event_status" }
      },
      "required": ["id", "category_id", "event_type", "format", "status"],
      "additionalProperties": false,
      "allOf": [
        {
          "description": "team_system MUST be set when event_type='teams' and NULL otherwise.",
          "if":   { "properties": { "event_type": { "const": "teams" } } },
          "then": { "required": ["team_system"], "properties": { "team_system": { "$ref": "#/$defs/team_system" } } },
          "else": { "properties": { "team_system": { "type": "null" } } }
        }
      ]
    },

    "tournament_payload": {
      "type": "object",
      "description": "Full snapshot of a tournament at pull time. Self-contained: every UUID referenced by registrations resolves inside this payload.",
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "generated_at": { "$ref": "#/$defs/iso_datetime" },
        "tenant": { "$ref": "#/$defs/tenant_branding" },
        "tournament": {
          "type": "object",
          "properties": {
            "id": { "$ref": "#/$defs/uuid" },
            "name": { "type": "string", "minLength": 1 },
            "starts_on": { "type": ["string", "null"], "format": "date" },
            "ends_on":   { "type": ["string", "null"], "format": "date" },
            "venue":     { "type": ["string", "null"] },
            "status":    { "$ref": "#/$defs/tournament_status" },
            "locked_by_device_id": { "type": ["string", "null"] },
            "locked_at": { "type": ["string", "null"], "format": "date-time" }
          },
          "required": ["id", "name", "status"],
          "additionalProperties": false
        },
        "categories": {
          "type": "array",
          "items": { "$ref": "#/$defs/category" }
        },
        "events": {
          "type": "array",
          "items": { "$ref": "#/$defs/event_spec" }
        },
        "players": {
          "type": "array",
          "items": { "$ref": "#/$defs/player" }
        },
        "pairs": {
          "type": "array",
          "items": { "$ref": "#/$defs/pair" },
          "description": "V2. Empty in V1 (RPC rejects doubles events)."
        },
        "teams": {
          "type": "array",
          "items": { "$ref": "#/$defs/team" },
          "description": "V2. Empty in V1."
        },
        "registrations": {
          "type": "array",
          "items": { "$ref": "#/$defs/registration" }
        }
      },
      "required": ["schema_version", "generated_at", "tenant", "tournament", "categories", "events", "players", "registrations"],
      "additionalProperties": false
    },

    "event_result_row": {
      "type": "object",
      "description": "Final placement for one competitor in one event. Composite key (event_id, placement) in cloud.",
      "properties": {
        "event_id": { "$ref": "#/$defs/uuid" },
        "placement": { "type": "integer", "minimum": 1 },
        "player_id": { "type": ["string", "null"], "format": "uuid" },
        "pair_id":   { "type": ["string", "null"], "format": "uuid" },
        "team_id":   { "type": ["string", "null"], "format": "uuid" },
        "points_awarded": { "type": ["integer", "null"], "minimum": 0 }
      },
      "required": ["event_id", "placement"],
      "additionalProperties": false,
      "allOf": [
        {
          "description": "Exactly one of player_id / pair_id / team_id must be non-null.",
          "oneOf": [
            { "required": ["player_id"], "properties": { "player_id": { "type": "string" } } },
            { "required": ["pair_id"],   "properties": { "pair_id":   { "type": "string" } } },
            { "required": ["team_id"],   "properties": { "team_id":   { "type": "string" } } }
          ]
        }
      ]
    },

    "event_results_block": {
      "type": "object",
      "description": "Results for one event being closed. Must include final placement for EVERY confirmed registration (no partial closure).",
      "properties": {
        "event_id": { "$ref": "#/$defs/uuid" },
        "results": {
          "type": "array",
          "items": { "$ref": "#/$defs/event_result_row" },
          "minItems": 1
        },
        "audit_blob": {
          "type": "object",
          "description": "Opaque desktop-side detail (groups, matches, sets, bracket, standings). Cloud stores in sync_ledger.payload_summary.audit_blob without parsing. Schema intentionally loose — desktop owns the format.",
          "additionalProperties": true
        }
      },
      "required": ["event_id", "results", "audit_blob"],
      "additionalProperties": false
    },

    "error_envelope": {
      "type": "object",
      "description": "Returned by RPCs on failure (HTTP 4xx/5xx via PostgREST).",
      "properties": {
        "error_code": {
          "type": "string",
          "enum": [
            "tournament_not_found",
            "tournament_not_ready",
            "tournament_locked_by_other_device",
            "schema_version_unsupported",
            "event_type_unsupported_in_v1",
            "event_not_part_of_tournament",
            "missing_results_for_registrations",
            "quota_exceeded",
            "permission_denied",
            "validation_error"
          ]
        },
        "message": { "type": "string" },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "description": "Context-specific. E.g. for tournament_locked_by_other_device: { locked_by_device_id, locked_at }. For quota_exceeded: { used, limit, period }."
        }
      },
      "required": ["error_code", "message"],
      "additionalProperties": false
    },

    "pull_tournament_request": {
      "type": "object",
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "tournament_id":  { "$ref": "#/$defs/uuid" },
        "device_id":      { "$ref": "#/$defs/device_id" },
        "force_acquire_lock": {
          "type": "boolean",
          "default": false,
          "description": "If true and tournament is locked by another device, steal the lock. Requires tenant_admin role. Default false → returns tournament_locked_by_other_device error."
        }
      },
      "required": ["schema_version", "tournament_id", "device_id"],
      "additionalProperties": false
    },

    "pull_tournament_response_ok": {
      "type": "object",
      "description": "Successful pull. Server-side effects: tournament.status → 'locked_for_run', locked_by_device_id set, locked_at = now(), sync_ledger row appended (kind='pull_tournament').",
      "properties": {
        "ok": { "const": true },
        "payload": { "$ref": "#/$defs/tournament_payload" },
        "lock": {
          "type": "object",
          "properties": {
            "device_id": { "$ref": "#/$defs/device_id" },
            "acquired_at": { "$ref": "#/$defs/iso_datetime" }
          },
          "required": ["device_id", "acquired_at"],
          "additionalProperties": false
        }
      },
      "required": ["ok", "payload", "lock"],
      "additionalProperties": false
    },

    "push_results_request": {
      "type": "object",
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "tournament_id":  { "$ref": "#/$defs/uuid" },
        "device_id":      { "$ref": "#/$defs/device_id" },
        "events": {
          "type": "array",
          "items": { "$ref": "#/$defs/event_results_block" },
          "minItems": 1,
          "description": "One block per event being closed. Multiple events can ship in a single call (typical: closing day = batch push). Atomic: either all succeed or all roll back."
        },
        "close_tournament": {
          "type": "boolean",
          "default": false,
          "description": "If true AND all events in tournament now have results, transition tournament.status → 'closed' and release the device lock."
        }
      },
      "required": ["schema_version", "tournament_id", "device_id", "events"],
      "additionalProperties": false
    },

    "push_results_response_ok": {
      "type": "object",
      "description": "All event_results rows written, sync_ledger appended (kind='push_results'), event.status → 'closed' for each pushed event.",
      "properties": {
        "ok": { "const": true },
        "events_closed": {
          "type": "array",
          "items": { "$ref": "#/$defs/uuid" },
          "description": "UUIDs of events whose status moved to 'closed' in this call."
        },
        "tournament_closed": {
          "type": "boolean",
          "description": "true iff close_tournament=true and all events are now closed."
        },
        "lock_released": {
          "type": "boolean",
          "description": "true iff tournament_closed=true."
        }
      },
      "required": ["ok", "events_closed", "tournament_closed", "lock_released"],
      "additionalProperties": false
    }
  },

  "endpoints": {
    "pull_tournament": {
      "summary": "Cloud → Desktop. Snapshot the tournament + register lock by device_id.",
      "transport": "Supabase RPC (PostgREST)",
      "rpc_name": "pull_tournament",
      "auth": "User JWT (Supabase Auth). Caller must be tenant_member of the tournament's tenant. RLS enforces.",
      "request": { "$ref": "#/$defs/pull_tournament_request" },
      "response_ok": { "$ref": "#/$defs/pull_tournament_response_ok" },
      "response_error": { "$ref": "#/$defs/error_envelope" },
      "preconditions": [
        "tournament.status IN ('registration_closed', 'locked_for_run')",
        "if status='locked_for_run' AND locked_by_device_id != caller's device_id AND force_acquire_lock=false → error tournament_locked_by_other_device",
        "quota: pull_tournament count this period < tenant.plan.pull_quota"
      ],
      "side_effects": [
        "UPDATE tournaments SET status='locked_for_run', locked_by_device_id=$device, locked_at=now() WHERE id=$tournament",
        "INSERT INTO sync_ledger (tenant_id, kind, resource_id, device_id, payload_summary) — payload_summary={events:N, players:N, registrations:N}"
      ],
      "idempotency": "Same device_id calling on already-locked-by-itself tournament returns 200 + fresh snapshot. Cheap to retry. Each successful call consumes 1 quota unit and writes 1 ledger row.",
      "errors": [
        { "code": "tournament_not_found",              "http": 404 },
        { "code": "tournament_not_ready",              "http": 409, "detail": "status is draft / registration_open" },
        { "code": "tournament_locked_by_other_device", "http": 409, "detail": "details.{locked_by_device_id, locked_at}" },
        { "code": "event_type_unsupported_in_v1",      "http": 422, "detail": "tournament has doubles or teams events — V1 rejects" },
        { "code": "schema_version_unsupported",        "http": 400 },
        { "code": "quota_exceeded",                    "http": 429 },
        { "code": "permission_denied",                 "http": 403 }
      ]
    },
    "push_results": {
      "summary": "Desktop → Cloud. Write final placements for closed events; optionally close the tournament and release the lock.",
      "transport": "Supabase RPC (PostgREST)",
      "rpc_name": "push_results",
      "auth": "User JWT. Caller must be tenant_member AND tournament.locked_by_device_id must equal request.device_id.",
      "request": { "$ref": "#/$defs/push_results_request" },
      "response_ok": { "$ref": "#/$defs/push_results_response_ok" },
      "response_error": { "$ref": "#/$defs/error_envelope" },
      "preconditions": [
        "tournament.status = 'locked_for_run'",
        "tournament.locked_by_device_id = request.device_id",
        "for every events[].event_id: event.tournament_id = request.tournament_id AND event.status != 'closed'",
        "for every events[]: results cover all confirmed registrations of that event (no partial)",
        "quota: push_results count this period < tenant.plan.push_quota"
      ],
      "side_effects": [
        "INSERT INTO event_results — one row per results[] item",
        "UPDATE events SET status='closed' WHERE id IN events[].event_id",
        "if close_tournament AND all events closed: UPDATE tournaments SET status='closed', locked_by_device_id=NULL, locked_at=NULL",
        "INSERT INTO sync_ledger — payload_summary={events:[...], results_count:N, audit_blobs:{event_id: <blob>}}"
      ],
      "idempotency": "Re-pushing the SAME event payload (matching event_id + identical results) returns 200 noop without inserting duplicate ledger row. Different results for an already-closed event returns validation_error (forces conflict resolution via staff intervention).",
      "errors": [
        { "code": "tournament_not_found",              "http": 404 },
        { "code": "tournament_locked_by_other_device", "http": 409 },
        { "code": "event_not_part_of_tournament",      "http": 422, "detail": "details.event_id" },
        { "code": "missing_results_for_registrations", "http": 422, "detail": "details.event_id, details.missing_registration_ids" },
        { "code": "schema_version_unsupported",        "http": 400 },
        { "code": "quota_exceeded",                    "http": 429 },
        { "code": "permission_denied",                 "http": 403 },
        { "code": "validation_error",                  "http": 422 }
      ]
    }
  },

